# AMLWire environment variables
# Copy to .env and fill in values

# NewsAPI (4 keys, 100 req/day each)
NEWSAPI_KEY_1=
NEWSAPI_KEY_2=
NEWSAPI_KEY_3=
NEWSAPI_KEY_4=

# SerpAPI (backfill only)
SERPAPI_KEY_1=
SERPAPI_KEY_2=

# OpenRouter
OPENROUTER_API_KEY=
OPENROUTER_MODEL=xiaomi/mimo-v2-pro

# Tavily (4 keys, 1000/month each)
TAVILY_API_KEY=
TAVILY_API_KEY_2=
TAVILY_API_KEY_3=
TAVILY_API_KEY_4=

# Additional news sources
NEWSDATA_API_KEY=
GNEWS_API_KEY=
THENEWSAPI_API_KEY=

# Supabase
SUPABASE_URL=
SUPABASE_SERVICE_KEY=

# Telegram daily report
Telegram_API_KEY=
TELEGRAM_CHAT_ID=
